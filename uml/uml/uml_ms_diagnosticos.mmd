---
title: HEPAQ - MS Diagnósticos (C4 Nivel 4 - Class Diagram)
---
classDiagram

    %% =====================
    %% ENUMS
    %% =====================

    class TipoDiagnostico {
        <<enumeration>>
        PRESUNTIVO
        DEFINITIVO
        DIFERENCIAL
        SECUNDARIO
    }

    class EstadoDiagnostico {
        <<enumeration>>
        ACTIVO
        RESUELTO
        CRONICO
        ELIMINADO
    }

    %% =====================
    %% DOMAIN
    %% =====================

    class Diagnostico {
        +UUID id
        +String pacienteId
        +String medicoId
        +UUID consultaId
        +String codigoCIE
        +String descripcion
        +TipoDiagnostico tipo
        +EstadoDiagnostico estado
        +String notasMedicas
        +String tratamientoSugerido
        +LocalDateTime fechaRegistro
        +LocalDateTime fechaActualizacion
        +resolver() void
        +marcarCronico() void
        +eliminar() void
        +estaActivo() boolean
    }

    class CodigoCIE {
        +String codigo
        +String descripcion
        +String categoria
        +String subcategoria
        +String codigoParent
        +boolean esTerminal
        +String descripcionLarga() String
        +boolean tieneSubcategorias() boolean
    }

    Diagnostico --> TipoDiagnostico
    Diagnostico --> EstadoDiagnostico

    %% =====================
    %% PATTERN: DECORATOR (Cache-Aside)
    %% Envuelve DiagnosticoRepositoryPort añadiendo cache Redis
    %% sin modificar el adaptador JPA subyacente
    %% =====================

    class DiagnosticoCacheDecorator {
        -delegate DiagnosticoRepositoryPort
        -redisAdapter DiagnosticoRedisAdapter
        -defaultTtl Duration
        +guardar(diagnostico Diagnostico) Diagnostico
        +obtener(id UUID) Optional~Diagnostico~
        +eliminar(id UUID) void
        -intentarDesdeCache(id UUID) Optional~Diagnostico~
        -actualizarCache(diagnostico Diagnostico) void
        -invalidarCache(id UUID) void
    }

    DiagnosticoCacheDecorator --> DiagnosticoRepositoryPort : delegate
    DiagnosticoCacheDecorator --> DiagnosticoRedisAdapter : cache

    %% =====================
    %% APPLICATION - USE CASES
    %% =====================

    class RegistrarDiagnosticoUseCase {
        -diagnosticoRepository DiagnosticoRepositoryPort
        -cieRepository CieRepositoryPort
        -eventPublisher EventPublisherPort
        +ejecutar(cmd RegistrarDiagnosticoCommand) Diagnostico
        -validarCodigoCIE(codigoCIE String) void
        -construirDiagnostico(cmd RegistrarDiagnosticoCommand) Diagnostico
    }

    class BorrarDiagnosticoUseCase {
        -diagnosticoRepository DiagnosticoRepositoryPort
        -eventPublisher EventPublisherPort
        +ejecutar(cmd BorrarDiagnosticoCommand) void
        -validarExiste(id UUID) Diagnostico
        -validarEliminable(diagnostico Diagnostico) void
    }

    RegistrarDiagnosticoUseCase --> DiagnosticoRepositoryPort
    RegistrarDiagnosticoUseCase --> CieRepositoryPort
    RegistrarDiagnosticoUseCase --> EventPublisherPort
    BorrarDiagnosticoUseCase --> DiagnosticoRepositoryPort
    BorrarDiagnosticoUseCase --> EventPublisherPort

    %% =====================
    %% COMMANDS
    %% =====================

    class RegistrarDiagnosticoCommand {
        +String pacienteId
        +String medicoId
        +UUID consultaId
        +String codigoCIE
        +String descripcion
        +TipoDiagnostico tipo
        +String notasMedicas
        +String tratamientoSugerido
    }

    class BorrarDiagnosticoCommand {
        +UUID diagnosticoId
        +String motivoBorrado
        +String medicoId
    }

    %% =====================
    %% QUERY SERVICES
    %% =====================

    class ObtenerDiagnosticoQuery {
        -diagnosticoCosmosAdapter DiagnosticoCosmosAdapter
        -diagnosticoRedisAdapter DiagnosticoRedisAdapter
        +ejecutar(id UUID) DiagnosticoDTO
        -buscarEnCache(id UUID) Optional~DiagnosticoDTO~
        -buscarEnCosmos(id UUID) DiagnosticoDTO
        -poblarCache(dto DiagnosticoDTO) void
    }

    class ListarDiagnosticosQuery {
        -diagnosticoCosmosAdapter DiagnosticoCosmosAdapter
        -diagnosticoRedisAdapter DiagnosticoRedisAdapter
        +ejecutar(pacienteId String) List~DiagnosticoDTO~
        +ejecutarPorConsulta(consultaId UUID) List~DiagnosticoDTO~
        +ejecutarActivos(pacienteId String) List~DiagnosticoDTO~
        -construirCacheKey(pacienteId String) String
    }

    class ListarCieQuery {
        -cieTableAdapter CieTableAdapter
        +ejecutar() List~CodigoCIEDTO~
        +ejecutarPorCategoria(categoria String) List~CodigoCIEDTO~
        +buscarPorCodigo(codigo String) CodigoCIEDTO
        +buscarPorDescripcion(termino String) List~CodigoCIEDTO~
    }

    ObtenerDiagnosticoQuery --> DiagnosticoCosmosAdapter
    ObtenerDiagnosticoQuery --> DiagnosticoRedisAdapter
    ListarDiagnosticosQuery --> DiagnosticoCosmosAdapter
    ListarDiagnosticosQuery --> DiagnosticoRedisAdapter
    ListarCieQuery --> CieTableAdapter

    %% =====================
    %% PORTS
    %% =====================

    class DiagnosticoRepositoryPort {
        <<interface>>
        +guardar(diagnostico Diagnostico) Diagnostico
        +obtener(id UUID) Optional~Diagnostico~
        +eliminar(id UUID) void
        +existePorConsulta(consultaId UUID) boolean
    }

    class DiagnosticoReadRepositoryPort {
        <<interface>>
        +obtenerPorId(id UUID) Optional~DiagnosticoDTO~
        +listarPorPaciente(pacienteId String) List~DiagnosticoDTO~
        +listarPorConsulta(consultaId UUID) List~DiagnosticoDTO~
        +listarActivos(pacienteId String) List~DiagnosticoDTO~
    }

    class CieRepositoryPort {
        <<interface>>
        +listar() List~CodigoCIE~
        +obtenerPorCodigo(codigo String) Optional~CodigoCIE~
        +listarPorCategoria(categoria String) List~CodigoCIE~
        +buscarPorDescripcion(termino String) List~CodigoCIE~
    }

    class EventPublisherPort {
        <<interface>>
        +publish(event DomainEvent) void
    }

    %% =====================
    %% ADAPTERS
    %% =====================

    class DiagnosticoJpaAdapter {
        -repository DiagnosticoJpaRepository
        -mapper DiagnosticoMapper
        +guardar(diagnostico Diagnostico) Diagnostico
        +obtener(id UUID) Optional~Diagnostico~
        +eliminar(id UUID) void
        +existePorConsulta(consultaId UUID) boolean
    }

    class DiagnosticoCosmosAdapter {
        -repository DiagnosticoCosmosRepository
        -mapper DiagnosticoMapper
        +obtenerPorId(id UUID) Optional~DiagnosticoDTO~
        +listarPorPaciente(pacienteId String) List~DiagnosticoDTO~
        +listarPorConsulta(consultaId UUID) List~DiagnosticoDTO~
        +listarActivos(pacienteId String) List~DiagnosticoDTO~
        +guardar(dto DiagnosticoDTO) void
        +actualizar(dto DiagnosticoDTO) void
    }

    class DiagnosticoRedisAdapter {
        -repository DiagnosticoRedisRepository
        -defaultTtl Duration
        +obtener(id UUID) Optional~DiagnosticoDTO~
        +guardar(id UUID, dto DiagnosticoDTO, ttl Duration) void
        +invalidar(id UUID) void
        +invalidarPorPaciente(pacienteId String) void
    }

    class CieTableAdapter {
        -repository CieTableRepository
        -mapper CieMapper
        -cacheLocal Map~String_CodigoCIE~
        +listar() List~CodigoCIE~
        +obtenerPorCodigo(codigo String) Optional~CodigoCIE~
        +listarPorCategoria(categoria String) List~CodigoCIE~
        +buscarPorDescripcion(termino String) List~CodigoCIE~
        -cargarCacheLocal() void
    }

    class ServiceBusPublisherAdapter {
        -senderClient ServiceBusSenderClient
        -topicName String
        +publish(event DomainEvent) void
        -serializar(event DomainEvent) String
        -construirMensaje(payload String) ServiceBusMessage
    }

    DiagnosticoRepositoryPort <|.. DiagnosticoJpaAdapter
    DiagnosticoRepositoryPort <|.. DiagnosticoCacheDecorator
    DiagnosticoReadRepositoryPort <|.. DiagnosticoCosmosAdapter
    CieRepositoryPort <|.. CieTableAdapter
    EventPublisherPort <|.. ServiceBusPublisherAdapter

    %% =====================
    %% EVENT CONSUMER
    %% =====================

    class BorrarDiagnosticosConsumer {
        -borrarUseCase BorrarDiagnosticoUseCase
        -objectMapper ObjectMapper
        +consume(message ServiceBusReceivedMessage) void
        -deserializar(payload String) List~BorrarDiagnosticoCommand~
        -procesarLote(commands List~BorrarDiagnosticoCommand~) void
        -manejarError(ex Exception) void
    }

    BorrarDiagnosticosConsumer --> BorrarDiagnosticoUseCase

    %% =====================
    %% REST LAYER
    %% =====================

    class DiagnosticosController {
        -delegate DiagnosticoDelegate
        +registrarDiagnostico(request RegistrarDiagnosticoRequest) ResponseEntity~DiagnosticoDTO~
        +borrarDiagnostico(id UUID) ResponseEntity~Void~
        +obtenerDiagnostico(id UUID) ResponseEntity~DiagnosticoDTO~
        +listarDiagnosticos(pacienteId String) ResponseEntity~List~DiagnosticoDTO~~
        +listarCIE(categoria String) ResponseEntity~List~CodigoCIEDTO~~
        +buscarCIE(codigo String) ResponseEntity~CodigoCIEDTO~
    }

    class DiagnosticoDelegate {
        -registrarUseCase RegistrarDiagnosticoUseCase
        -borrarUseCase BorrarDiagnosticoUseCase
        -obtenerQuery ObtenerDiagnosticoQuery
        -listarQuery ListarDiagnosticosQuery
        -listarCieQuery ListarCieQuery
        -mapper DiagnosticoMapper
        +registrar(request RegistrarDiagnosticoRequest) DiagnosticoDTO
        +borrar(id UUID) void
        +obtener(id UUID) DiagnosticoDTO
        +listar(pacienteId String) List~DiagnosticoDTO~
        +listarCIE(categoria String) List~CodigoCIEDTO~
        +buscarCIE(codigo String) CodigoCIEDTO
    }

    class DiagnosticoMapper {
        +toDTO(diagnostico Diagnostico) DiagnosticoDTO
        +toDomain(request RegistrarDiagnosticoRequest) Diagnostico
        +toCommand(request RegistrarDiagnosticoRequest) RegistrarDiagnosticoCommand
        +toEntity(diagnostico Diagnostico) DiagnosticoEntity
        +toDomainFromEntity(entity DiagnosticoEntity) Diagnostico
        +cieToCIEDTO(cie CodigoCIE) CodigoCIEDTO
    }

    class DiagnosticoEventPublisher {
        -eventPublisher EventPublisherPort
        +publicarDiagnosticoRegistrado(diagnostico Diagnostico) void
        +publicarDiagnosticoEliminado(diagnostico Diagnostico) void
    }

    DiagnosticosController --> DiagnosticoDelegate
    DiagnosticoDelegate --> RegistrarDiagnosticoUseCase
    DiagnosticoDelegate --> BorrarDiagnosticoUseCase
    DiagnosticoDelegate --> ObtenerDiagnosticoQuery
    DiagnosticoDelegate --> ListarDiagnosticosQuery
    DiagnosticoDelegate --> ListarCieQuery
    DiagnosticoDelegate --> DiagnosticoMapper
    DiagnosticoEventPublisher --> EventPublisherPort
    DiagnosticoJpaAdapter --> DiagnosticoMapper
    DiagnosticoCosmosAdapter --> DiagnosticoMapper
    CieTableAdapter --> CodigoCIE
