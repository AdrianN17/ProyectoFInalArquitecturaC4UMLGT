---
title: HEPAQ - MS Citas (C4 Nivel 4 - Class Diagram)
---
classDiagram

    %% =====================
    %% ENUMS
    %% =====================

    class TipoCita {
        <<enumeration>>
        CONSULTA_MEDICA
        LABORATORIO
        ECOGRAFIA
    }

    class EstadoCita {
        <<enumeration>>
        PENDIENTE
        CONFIRMADA
        CANCELADA
        REPROGRAMADA
    }

    %% =====================
    %% DOMAIN
    %% =====================

    class Cita {
        +UUID id
        +String pacienteId
        +String medicoId
        +LocalDateTime fechaHora
        +TipoCita tipo
        +EstadoCita estado
        +String motivoCita
        +LocalDateTime fechaCreacion
        +LocalDateTime fechaActualizacion
        +confirmar() void
        +cancelar(motivo String) void
        +reagendar(nuevaFecha LocalDateTime) void
        +esPendiente() boolean
        +esConfirmada() boolean
    }

    Cita --> TipoCita
    Cita --> EstadoCita

    %% =====================
    %% PATTERN: STRATEGY
    %% Lógica de agendamiento según el tipo de cita
    %% =====================

    class AgendaStrategy {
        <<interface>>
        +validar(cita Cita) void
        +reservar(cita Cita) Cita
    }

    class ConsultaMedicaStrategy {
        -medicoPort MedicoPort
        +validar(cita Cita) void
        +reservar(cita Cita) Cita
        -verificarHorario(medicoId String, fecha LocalDateTime) boolean
    }

    class LaboratorioStrategy {
        -medicoPort MedicoPort
        +validar(cita Cita) void
        +reservar(cita Cita) Cita
        -verificarCapacidad(fecha LocalDateTime) boolean
    }

    class EcografiaStrategy {
        -medicoPort MedicoPort
        +validar(cita Cita) void
        +reservar(cita Cita) Cita
        -verificarEquipo(fecha LocalDateTime) boolean
    }

    AgendaStrategy <|.. ConsultaMedicaStrategy
    AgendaStrategy <|.. LaboratorioStrategy
    AgendaStrategy <|.. EcografiaStrategy
    ConsultaMedicaStrategy --> MedicoPort
    LaboratorioStrategy --> MedicoPort
    EcografiaStrategy --> MedicoPort

    %% =====================
    %% PATTERN: CHAIN OF RESPONSIBILITY
    %% Cadena de validaciones previas al agendamiento
    %% =====================

    class ValidacionCitaHandler {
        <<abstract>>
        #siguiente ValidacionCitaHandler
        +setNext(handler ValidacionCitaHandler) ValidacionCitaHandler
        +validar(cita Cita) void
    }

    class ReniecValidacionHandler {
        -reniecPort ReniecPort
        +validar(cita Cita) void
        -validarDNI(pacienteId String) boolean
    }

    class SeguroValidacionHandler {
        -seguroPort SeguroPort
        +validar(cita Cita) void
        -verificarCobertura(pacienteId String) boolean
    }

    class DisponibilidadMedicoHandler {
        -medicoPort MedicoPort
        +validar(cita Cita) void
        -consultarDisponibilidad(medicoId String, fecha LocalDateTime) boolean
    }

    ValidacionCitaHandler <|-- ReniecValidacionHandler
    ValidacionCitaHandler <|-- SeguroValidacionHandler
    ValidacionCitaHandler <|-- DisponibilidadMedicoHandler
    ValidacionCitaHandler --> ValidacionCitaHandler : siguiente
    ReniecValidacionHandler --> ReniecPort
    SeguroValidacionHandler --> SeguroPort
    DisponibilidadMedicoHandler --> MedicoPort

    %% =====================
    %% PATTERN: FACTORY METHOD
    %% =====================

    class AgendaStrategyFactory {
        -strategies Map~TipoCita_AgendaStrategy~
        +obtener(tipo TipoCita) AgendaStrategy
        -registrar(tipo TipoCita, strategy AgendaStrategy) void
    }

    AgendaStrategyFactory --> AgendaStrategy

    %% =====================
    %% COMMANDS
    %% =====================

    class AgendarCitaCommand {
        +String pacienteId
        +String medicoId
        +LocalDateTime fechaHora
        +TipoCita tipo
        +String motivoCita
    }

    class ReagendarCitaCommand {
        +UUID citaId
        +LocalDateTime nuevaFechaHora
        +String motivoReagenda
    }

    class CancelarCitaCommand {
        +UUID citaId
        +String motivoCancelacion
    }

    %% =====================
    %% APPLICATION - USE CASES
    %% =====================

    class AgendarCitaUseCase {
        -citaRepository CitaRepositoryPort
        -eventPublisher EventPublisherPort
        -validacionChain ValidacionCitaHandler
        -strategyFactory AgendaStrategyFactory
        +ejecutar(cmd AgendarCitaCommand) Cita
        -construirCita(cmd AgendarCitaCommand) Cita
    }

    class ReagendarCitaUseCase {
        -citaRepository CitaRepositoryPort
        -eventPublisher EventPublisherPort
        +ejecutar(cmd ReagendarCitaCommand) Cita
    }

    class CancelarCitaUseCase {
        -citaRepository CitaRepositoryPort
        -eventPublisher EventPublisherPort
        +ejecutar(cmd CancelarCitaCommand) void
    }

    AgendarCitaUseCase --> CitaRepositoryPort
    AgendarCitaUseCase --> EventPublisherPort
    AgendarCitaUseCase --> ValidacionCitaHandler
    AgendarCitaUseCase --> AgendaStrategyFactory
    AgendarCitaUseCase ..> AgendarCitaCommand
    ReagendarCitaUseCase --> CitaRepositoryPort
    ReagendarCitaUseCase --> EventPublisherPort
    ReagendarCitaUseCase ..> ReagendarCitaCommand
    CancelarCitaUseCase --> CitaRepositoryPort
    CancelarCitaUseCase --> EventPublisherPort
    CancelarCitaUseCase ..> CancelarCitaCommand

    %% =====================
    %% QUERY SERVICES
    %% =====================

    class ListarCitaQuery {
        -citaCosmosAdapter CitaCosmosAdapter
        -citaRedisAdapter CitaRedisAdapter
        +ejecutar(pacienteId String, fecha LocalDateTime) List~CitaDTO~
        -construirFiltros(pacienteId String) Map~String_Object~
    }

    class ObtenerCitaQuery {
        -citaCosmosAdapter CitaCosmosAdapter
        -citaRedisAdapter CitaRedisAdapter
        +ejecutar(id UUID) CitaDTO
        -buscarEnCache(id UUID) Optional~CitaDTO~
    }

    ListarCitaQuery --> CitaCosmosAdapter
    ListarCitaQuery --> CitaRedisAdapter
    ObtenerCitaQuery --> CitaCosmosAdapter
    ObtenerCitaQuery --> CitaRedisAdapter

    %% =====================
    %% PORTS
    %% =====================

    class CitaRepositoryPort {
        <<interface>>
        +guardar(cita Cita) Cita
        +obtener(id UUID) Optional~Cita~
        +actualizar(cita Cita) Cita
        +existePorPacienteYFecha(pacienteId String, fecha LocalDateTime) boolean
    }

    class SeguroPort {
        <<interface>>
        +validarCobertura(pacienteId String, tipo TipoCita) boolean
        +obtenerDatosSeguro(pacienteId String) SeguroDTO
    }

    class ReniecPort {
        <<interface>>
        +validarIdentidad(pacienteId String) boolean
        +obtenerDatosPaciente(pacienteId String) PacienteDTO
    }

    class MedicoPort {
        <<interface>>
        +obtenerDisponibilidad(medicoId String, fecha LocalDateTime) List~SlotDTO~
        +obtenerMedico(medicoId String) MedicoDTO
    }

    class EventPublisherPort {
        <<interface>>
        +publish(event DomainEvent) void
    }

    %% =====================
    %% ADAPTERS
    %% =====================

    class CitaJpaAdapter {
        -repository CitaJpaRepository
        -mapper CitaMapper
        +guardar(cita Cita) Cita
        +obtener(id UUID) Optional~Cita~
        +actualizar(cita Cita) Cita
        +existePorPacienteYFecha(pacienteId String, fecha LocalDateTime) boolean
    }

    class CitaCosmosAdapter {
        -repository CitaCosmosRepository
        -mapper CitaMapper
        +obtenerPorId(id UUID) Optional~CitaDTO~
        +listar(pacienteId String) List~CitaDTO~
        +guardar(citaDTO CitaDTO) void
        +actualizar(citaDTO CitaDTO) void
    }

    class CitaRedisAdapter {
        -repository CitaRedisRepository
        +obtener(id UUID) Optional~CitaDTO~
        +guardar(id UUID, dto CitaDTO, ttl Duration) void
        +invalidar(id UUID) void
        +invalidarPorPaciente(pacienteId String) void
    }

    class MedicosRedisAdapter {
        -medicosRedisRepository MedicosRedisRepository
        -medicosWebClient MedicosWebClient
        +obtenerMedico(medicoId String) MedicoDTO
        +cargarEnCache(medicoId String) void
        -hayCache(medicoId String) boolean
    }

    class SeguroAdapter {
        -webClient SeguroWebClient
        -baseUrl String
        +validarCobertura(pacienteId String, tipo TipoCita) boolean
        +obtenerDatosSeguro(pacienteId String) SeguroDTO
    }

    class ReniecAdapter {
        -webClient ReniecWebClient
        -apiKey String
        +validarIdentidad(pacienteId String) boolean
        +obtenerDatosPaciente(pacienteId String) PacienteDTO
    }

    class MedicoAdapter {
        -medicosRedisAdapter MedicosRedisAdapter
        -medicosWebClient MedicosWebClient
        +obtenerDisponibilidad(medicoId String, fecha LocalDateTime) List~SlotDTO~
        +obtenerMedico(medicoId String) MedicoDTO
    }

    class ServiceBusPublisherAdapter {
        -senderClient ServiceBusSenderClient
        -topicName String
        +publish(event DomainEvent) void
        -serializar(event DomainEvent) String
        -construirMensaje(payload String) ServiceBusMessage
    }

    CitaRepositoryPort <|.. CitaJpaAdapter
    SeguroPort <|.. SeguroAdapter
    ReniecPort <|.. ReniecAdapter
    MedicoPort <|.. MedicoAdapter
    EventPublisherPort <|.. ServiceBusPublisherAdapter
    MedicoAdapter --> MedicosRedisAdapter

    %% =====================
    %% EVENT CONSUMER
    %% =====================

    class AgendarCitaConsumer {
        -agendarUseCase AgendarCitaUseCase
        -objectMapper ObjectMapper
        +consume(message ServiceBusReceivedMessage) void
        -deserializar(payload String) AgendarCitaCommand
        -manejarError(ex Exception, message ServiceBusReceivedMessage) void
    }

    AgendarCitaConsumer --> AgendarCitaUseCase

    %% =====================
    %% REST LAYER
    %% =====================

    class CitasController {
        -delegate CitaDelegate
        +agendarCita(request AgendarCitaRequest) ResponseEntity~CitaDTO~
        +reagendarCita(id UUID, request ReagendarCitaRequest) ResponseEntity~CitaDTO~
        +cancelarCita(id UUID, request CancelarCitaRequest) ResponseEntity~Void~
        +listarCitas(pacienteId String, fecha String) ResponseEntity~List~CitaDTO~~
        +obtenerCita(id UUID) ResponseEntity~CitaDTO~
    }

    class CitaDelegate {
        -agendarUseCase AgendarCitaUseCase
        -reagendarUseCase ReagendarCitaUseCase
        -cancelarUseCase CancelarCitaUseCase
        -listarQuery ListarCitaQuery
        -obtenerQuery ObtenerCitaQuery
        -mapper CitaMapper
        +agendar(request AgendarCitaRequest) CitaDTO
        +reagendar(id UUID, request ReagendarCitaRequest) CitaDTO
        +cancelar(id UUID, request CancelarCitaRequest) void
        +listar(pacienteId String, fecha String) List~CitaDTO~
        +obtener(id UUID) CitaDTO
    }

    class CitaMapper {
        +toDTO(cita Cita) CitaDTO
        +toDomain(request AgendarCitaRequest) Cita
        +toCommand(request AgendarCitaRequest) AgendarCitaCommand
        +toEntity(cita Cita) CitaEntity
        +toDomainFromEntity(entity CitaEntity) Cita
    }

    class CitaEventPublisher {
        -eventPublisher EventPublisherPort
        +publicarCitaAgendada(cita Cita) void
        +publicarCitaCancelada(cita Cita) void
        +publicarCitaReagendada(cita Cita) void
    }

    CitasController --> CitaDelegate
    CitaDelegate --> AgendarCitaUseCase
    CitaDelegate --> ReagendarCitaUseCase
    CitaDelegate --> CancelarCitaUseCase
    CitaDelegate --> ListarCitaQuery
    CitaDelegate --> ObtenerCitaQuery
    CitaDelegate --> CitaMapper
    CitaEventPublisher --> EventPublisherPort
